# 이 파일을 config/runtime.env 로 복사한 뒤 필요한 값을 채우면 됩니다.
# scripts/run_daily_refresh.sh 는 config/runtime.env 가 있으면 자동으로 읽습니다.

# 텔레그램 알림
STOCK_REPORT_TELEGRAM_BOT_TOKEN=
STOCK_REPORT_TELEGRAM_CHAT_ID=

# 선택: 일부 심볼만 실행
# STOCK_REPORT_SYMBOLS="SPY NVDA SNDK SMH"

# 선택: 실행 옵션 덮어쓰기
# STOCK_REPORT_BENCHMARK=SPY
# STOCK_REPORT_HISTORY_RANGE=1y
# STOCK_REPORT_NEWS_DAYS=7
